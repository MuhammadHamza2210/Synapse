# Copy this file to .env and fill in what you have. Everything works without a key.

# --- LLM (all optional — app works with none of them) -------------------------
# Provider resolution: auto | ollama | claude | off
#   auto   -> use local Ollama if running, else Claude (if key set), else extractive
LLM_PROVIDER=auto

# Ollama: FREE, local, no API key. Install from https://ollama.com then:
#   ollama pull llama3.2:1b   (then `ollama serve` runs automatically)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Google Gemini (free tier). Set GEMINI_API_KEY to enable hosted AI in the cloud.
# With LLM_PROVIDER=gemini the app uses Gemini directly (used in the live demo).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Claude (optional, paid). Leave blank to ignore.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Database -----------------------------------------------------------------
DATABASE_URL=sqlite:///./synapse.db

# --- Retrieval / chunking -----------------------------------------------------
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=6
EMBEDDING_DIM=384

# --- CORS (frontend dev server) -----------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
